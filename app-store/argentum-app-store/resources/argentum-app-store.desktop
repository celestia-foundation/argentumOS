[Desktop Entry]
Name=App Store
GenericName=Software
Comment=Discover and install apps from Flathub
Exec=argentum-app-store %U
Icon=system-software-install
Terminal=false
Type=Application
Categories=System;PackageManager;
Keywords=flatpak;flathub;apps;install;software;store;
MimeType=x-scheme-handler/appstream;x-scheme-handler/mintinstall;application/vnd.flatpak;application/vnd.flatpak.ref;
StartupNotify=true
StartupWMClass=argentum-app-store
