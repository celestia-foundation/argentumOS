[Desktop Entry]
Name=App Store
GenericName=Software
Comment=Discover and install apps from Flathub
Exec=argentum-app-store
Icon=system-software-install
Terminal=false
Type=Application
Categories=System;PackageManager;
Keywords=flatpak;flathub;apps;install;software;store;
StartupNotify=true
StartupWMClass=argentum-app-store
